{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Flutter in Chrome",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "deviceId": "chrome",
            "toolArgs": ["--web-port", "5173"],
            "args": [
                "--dart-define=AI_API_BASE_URL=http://127.0.0.1:5001"
            ]
        }
    ]
}